{
  "markdown_preview_font_family": "Ioskeley Mono",
  "markdown_preview_code_font_family": "IoskeleyMono Nerd Font",
  "soft_wrap": "none",
  "proxy": "",
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "theme": {
    "mode": "dark",
    "light": "Kintsugi Light Flared",
    "dark": "Kintsugi Dark Flared"
  },
  "ui_font_family": "Ioskeley Mono",
  "ui_font_size": 17.0,
  "buffer_font_family": "IoskeleyMono Nerd Font",
  "buffer_font_size": 16.0,
  "buffer_line_height": "comfortable",
  "buffer_font_features": {
    "aalt": true
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Bearded Icons",
    "dark": "Bearded Icons"
  },
  "autosave": "on_focus_change",
  "vim_mode": true,
  "cli_default_open_behavior": "new_window",
  "diff_view_style": "unified",
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tab_bar": {
    "show": true
  },
  "tabs": {
    "file_icons": false,
    "git_status": false
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false
  },
  "git_panel": {
    "show_count_badge": true,
    "dock": "left",
    "collapse_untracked_diff": true,
    "tree_view": true,
    "status_style": "icon"
  },
  "project_panel": {
    "diagnostic_badges": false,
    "dock": "left",
    "hide_hidden": false,
    "hide_root": true,
    "bold_folder_labels": true,
    "entry_spacing": "comfortable",
    "hide_gitignore": false
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left"
  },
  "terminal": {
    "font_family": "IoskeleyMonoTerm Nerd Font",
    "show_count_badge": false,
    "dock": "right",
    "toolbar": {
      "breadcrumbs": true
    }
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "react-doctor": {
      "binary": {
        "path": "/Users/ray/.bun/bin/react-doctor",
        "arguments": ["experimental-lsp", "--stdio"]
      },
      "initialization_options": {
        "scanOnType": true
      }
    }
  },
  "languages": {
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "GraphQL": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Handlebars": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JavaScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSON5": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Less": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "MDX": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "SCSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TypeScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Vue.js": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "YAML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    }
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "agent": {
    "dock": "right",
    "enabled": false
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "ssh_connections": [
    {
      "host": "server",
      "args": [],
      "projects": []
    }
  ],
  "redact_private_values": false,
  "session": {
    "trust_all_worktrees": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
